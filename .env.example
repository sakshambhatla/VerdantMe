# Set the key for whichever provider you use in config.json

# Anthropic (Claude) — https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-key-here

# Google Gemini — https://aistudio.google.com
GEMINI_API_KEY=your-gemini-key-here

# Supabase (optional — omit for local-only JSON storage)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWT_SECRET=

# CORS origins (comma-separated; defaults to http://localhost:5173)
CORS_ORIGINS=http://localhost:5173
